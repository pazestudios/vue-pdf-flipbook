{
  "name": "vue-pdf-flipbook",
  "version": "0.1.0",
  "description": "A headless Vue 3 PDF flipbook component with realistic page-turn animation, customizable with Tailwind or any CSS",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/vue-pdf-flipbook.js",
  "module": "./dist/vue-pdf-flipbook.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-pdf-flipbook.js"
    },
    "./style.css": "./dist/vue-pdf-flipbook.css",
    "./package.json": "./package.json"
  },
  "keywords": [
    "vue",
    "vue3",
    "pdf",
    "flipbook",
    "page-flip",
    "pdfjs",
    "component",
    "headless",
    "tailwind"
  ],
  "scripts": {
    "dev": "vite --config playground/vite.config.ts",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "pdfjs-dist": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^15.11.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.2.7",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0"
  }
}
